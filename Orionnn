function OrionLib:MakeNotification(cfg)

    cfg = cfg or {}

    local name = cfg.Name or "Notification"
    local content = cfg.Content or "Content"
    local time = cfg.Time or 5

    local Frame = Create("Frame",{

        Size = UDim2.new(1,0,0,60),
        BackgroundColor3 = OrionLib.Themes.Default.Second,
        BorderSizePixel = 0

    },{
        MakeElement("Corner",0,8),
        MakeElement("Stroke")
    })

    Frame.Parent = NotificationHolder

    local Title = MakeElement("Label",name,15)
    Title.Font = Enum.Font.GothamBold
    Title.Position = UDim2.new(0,10,0,6)
    Title.Parent = Frame

    local Content = MakeElement("Label",content,13)
    Content.TextColor3 = Color3.fromRGB(200,200,200)
    Content.Position = UDim2.new(0,10,0,26)
    Content.Parent = Frame

    TweenService:Create(Frame,TweenInfo.new(.3),{
        BackgroundTransparency = 0
    }):Play()

    task.wait(time)

    TweenService:Create(Frame,TweenInfo.new(.4),{
        BackgroundTransparency = 1
    }):Play()

    task.wait(.4)

    Frame:Destroy()

end


