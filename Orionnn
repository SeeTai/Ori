            Button.MouseButton1Click:Connect(function()

                local option =
                    Options[math.random(1,#Options)]

                Label.Text =
                    (Config.Name or "Dropdown") .. ": " .. option

                if Config.Callback then
                    Config.Callback(option)
                end

            end)

