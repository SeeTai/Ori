------------------------------------------------
-- SLIDER
------------------------------------------------

        function Elements:AddSlider(Config)

            Config = Config or {}

            local Min = Config.Min or 0
            local Max = Config.Max or 100
            local Value = Config.Default or 50

            local Frame = MakeElement("Frame")
            Frame.Size = UDim2.new(1,0,0,60)
            Frame.BackgroundColor3 = OrionLib.Themes.Default.Second
            Frame.Parent = TabContainer

            MakeElement("Corner",0,6).Parent = Frame
            MakeElement("Stroke").Parent = Frame

            local Label = MakeElement("Label",Config.Name or "Slider",14)
            Label.Position = UDim2.new(0,10,0,8)
            Label.Parent = Frame

            local Bar = MakeElement("Frame")
            Bar.Size = UDim2.new(1,-20,0,20)
            Bar.Position = UDim2.new(0,10,0,30)
            Bar.BackgroundColor3 = Color3.fromRGB(50,50,50)
            Bar.Parent = Frame

            local Fill = MakeElement("Frame")
            Fill.Size = UDim2.new(Value/Max,0,1,0)
            Fill.BackgroundColor3 = Color3.fromRGB(0,170,120)
            Fill.Parent = Bar

            Bar.InputBegan:Connect(function(input)

                if input.UserInputType == Enum.UserInputType.MouseButton1 then

                    local Move

                    Move = UserInputService.InputChanged:Connect(function(i)

                        if i.UserInputType == Enum.UserInputType.MouseMovement then

                            local percent =
                                math.clamp(
                                    (Mouse.X - Bar.AbsolutePosition.X)
                                    / Bar.AbsoluteSize.X,
                                    0,
                                    1
                                )

                            Value =
                                math.floor(
                                    Min + (Max - Min) * percent
                                )

                            Fill.Size = UDim2.new(percent,0,1,0)

                            if Config.Callback then
                                Config.Callback(Value)
                            end

                        end

                    end)

                    UserInputService.InputEnded:Connect(function(i)

                        if i.UserInputType ==
                            Enum.UserInputType.MouseButton1 then

                            Move:Disconnect()

                        end

                    end)

                end

            end)

        end

