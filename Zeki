					end)
				end

				local function UpdateFromInput(x)
					local alpha = math.clamp((x - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1)
					local value = Min + ((Max - Min) * alpha)
					SliderAPI:Set(value)
				end

				Connect(Bar.InputBegan, function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						Dragging = true
						UpdateFromInput(input.Position.X)
					end
				end)

				Connect(UserInputService.InputChanged, function(input)
					if Dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
						UpdateFromInput(input.Position.X)
					end
				end)

				Connect(UserInputService.InputEnded, function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						Dragging = false
					end
				end)

				SliderAPI:Set(Default)
				return SliderAPI
			end

			function SectionMethods:AddDropdown(dropCfg)
				dropCfg = dropCfg or {}
				local Name = dropCfg.Name or "Dropdown"
				local Options = dropCfg.Options or {}
				local Default = dropCfg.Default or Options[1] or "None"
				local Flag = dropCfg.Flag
				local Callback = dropCfg.Callback or function() end
				local Open = false

				local MainDrop = Create("Frame", {
					Parent = Inner,
					Size = UDim2.new(1, 0, 0, 42),
					BackgroundColor3 = Library.Theme.Card2,
					BorderSizePixel = 0,
					ClipsDescendants = true
				}, {
					Corner(10),
					Stroke(Library.Theme.Stroke, 1)
				})

				local Click = MakeButtonBase()
				Click.Parent = MainDrop
				Click.Size = UDim2.new(1, 0, 0, 42)

				local NameLabel = MakeTextLabel(Name, 14, Library.Theme.SubText, Enum.Font.GothamMedium)
				NameLabel.Parent = MainDrop
				NameLabel.Position = UDim2.new(0, 14, 0, 0)
				NameLabel.Size = UDim2.new(0.5, 0, 0, 42)

				local Selected = MakeTextLabel(Default, 13, Library.Theme.Text, Enum.Font.Gotham, Enum.TextXAlignment.Right)
				Selected.Parent = MainDrop
				Selected.Position = UDim2.new(0.5, 0, 0, 0)
				Selected.Size = UDim2.new(0.5, -38, 0, 42)

				local Arrow = Create("ImageLabel", {
					Parent = MainDrop,
					AnchorPoint = Vector2.new(1, 0.5),
					Position = UDim2.new(1, -14, 0.5, 0),
					Size = UDim2.new(0, 16, 0, 16),
					BackgroundTransparency = 1,
					Image = "rbxassetid://3926305904",
					ImageRectOffset = Vector2.new(324, 524),
					ImageRectSize = Vector2.new(36, 36),
					ImageColor3 = Library.Theme.SubText
				})

				local OptionsHolder = Create("Frame", {
					Parent = MainDrop,
					Position = UDim2.new(0, 0, 0, 42),
					Size = UDim2.new(1, 0, 0, 0),
					BackgroundTransparency = 1,
					ClipsDescendants = true
				}, {
					ListLayout(6, false),
					Padding(8, 8, 0, 8)
				})

				local DropAPI = {Value = Default}
				if Flag then
					Library.Flags[Flag] = DropAPI
				end

				function DropAPI:Set(v)
					self.Value = v
					Selected.Text = tostring(v)
					task.spawn(function()
						Callback(v)
					end)
				end

				for _, option in ipairs(Options) do
					local Opt = Create("TextButton", {
						Parent = OptionsHolder,
						Size = UDim2.new(1, 0, 0, 30),
						BackgroundColor3 = Library.Theme.Window,
						BorderSizePixel = 0,
						Text = "",
						AutoButtonColor = false
					}, {
						Corner(8)
					})

					local OptText = MakeTextLabel(tostring(option), 13, Library.Theme.Text, Enum.Font.Gotham)
					OptText.Parent = Opt
					OptText.Position = UDim2.new(0, 10, 0, 0)
					OptText.Size = UDim2.new(1, -20, 1, 0)

					Connect(Opt.MouseEnter, function()
						TweenService:Create(Opt, TweenInfo.new(0.12), {
							BackgroundColor3 = Library.Theme.DropdownHover
						}):Play()
					end)

					Connect(Opt.MouseLeave, function()
						TweenService:Create(Opt, TweenInfo.new(0.12), {
							BackgroundColor3 = Library.Theme.Window
						}):Play()
					end)

					Connect(Opt.MouseButton1Click, function()
						DropAPI:Set(option)
						Open = false
						TweenService:Create(MainDrop, TweenInfo.new(0.18), {
							Size = UDim2.new(1, 0, 0, 42)
						}):Play()
						TweenService:Create(Arrow, TweenInfo.new(0.18), {
							Rotation = 0
						}):Play()
						OptionsHolder.Size = UDim2.new(1, 0, 0, 0)
					end)
				end

				Connect(Click.MouseButton1Click, function()
					Open = not Open
					local openSize = 42 + (#Options * 36) + 8

					TweenService:Create(MainDrop, TweenInfo.new(0.18), {
						Size = Open and UDim2.new(1, 0, 0, openSize) or UDim2.new(1, 0, 0, 42)
					}):Play()

					TweenService:Create(Arrow, TweenInfo.new(0.18), {
						Rotation = Open and 180 or 0
					}):Play()

					OptionsHolder.Size = Open and UDim2.new(1, 0, 0, #Options * 36) or UDim2.new(1, 0, 0, 0)
				end)

				DropAPI:Set(Default)
				return DropAPI
			end

			Connect(Inner.UIListLayout:GetPropertyChangedSignal("AbsoluteContentSize"), function()
				Section.Size = UDim2.new(1, 0, 0, Inner.UIListLayout.AbsoluteContentSize.Y + 32)
			end)

			return SectionMethods
		end

		return TabMethods
	end

	Connect(UserInputService.InputBegan, function(input, gp)
		if gp then return end
		if input.KeyCode == HideKey then
			hidden = not hidden
			Main.Visible = not hidden
		end
	end)

	if Intro then
		Main.Visible = false

		local IntroFrame = Create("Frame", {
			Parent = ScreenGui,
			Size = UDim2.new(1, 0, 1, 0),
			BackgroundColor3 = Color3.fromRGB(0, 0, 0),
			BackgroundTransparency = 0.35
		})

		local IntroText = MakeTextLabel(WindowTitle, 22, Library.Theme.Text, Enum.Font.GothamBold, Enum.TextXAlignment.Center)
		IntroText.Parent = IntroFrame
		IntroText.AnchorPoint = Vector2.new(0.5, 0.5)
		IntroText.Position = UDim2.new(0.5, 0, 0.5, 0)
		IntroText.Size = UDim2.new(0, 300, 0, 40)
		IntroText.TextTransparency = 1

		TweenService:Create(IntroText, TweenInfo.new(0.25), {
			TextTransparency = 0
		}):Play()

		task.delay(1.1, function()
			TweenService:Create(IntroText, TweenInfo.new(0.25), {
				TextTransparency = 1
			}):Play()
			task.wait(0.25)
			IntroFrame:Destroy()
			Main.Visible = true
		end)
	end

	return WindowMethods
end

return Library
