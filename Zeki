	local function SelectTab(button, icon, label, page, name)
		if currentTabButton and currentTabButton ~= button then
			local oldIcon = currentTabButton:FindFirstChild("TabIcon")
			local oldLabel = currentTabButton:FindFirstChild("TabLabel")
			local oldStroke = currentTabButton:FindFirstChildOfClass("UIStroke")

			TweenService:Create(currentTabButton, TweenInfo.new(0.2), {
				BackgroundTransparency = 1
			}):Play()

			if oldStroke then
				TweenService:Create(oldStroke, TweenInfo.new(0.2), {
					Transparency = 1
				}):Play()
			end

			if oldIcon then
				TweenService:Create(oldIcon, TweenInfo.new(0.2), {
					ImageColor3 = Library.Theme.SubText
				}):Play()
			end

			if oldLabel then
				TweenService:Create(oldLabel, TweenInfo.new(0.2), {
					TextColor3 = Library.Theme.SubText
				}):Play()
			end
		end

		if currentTabPage then
			currentTabPage.Visible = false
		end

		currentTabButton = button
		currentTabPage = page
		page.Visible = true
		PageTitle.Text = name

		local stroke = button:FindFirstChildOfClass("UIStroke")
		TweenService:Create(button, TweenInfo.new(0.2), {
			BackgroundTransparency = 0,
			BackgroundColor3 = Library.Theme.Card
		}):Play()

		if stroke then
			TweenService:Create(stroke, TweenInfo.new(0.2), {
				Transparency = 0
			}):Play()
		end

		TweenService:Create(icon, TweenInfo.new(0.2), {
			ImageColor3 = Library.Theme.Text
		}):Play()

		TweenService:Create(label, TweenInfo.new(0.2), {
			TextColor3 = Library.Theme.Text
		}):Play()
	end

